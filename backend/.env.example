########################################
# Production-ready .env.example
########################################

# Server
# Port is provided by Render via `PORT` environment variable; keep a fallback
PORT=5000
NODE_ENV=production

# Security
# Use a strong secret for signing JWTs in production
JWT_SECRET=replace_this_with_a_strong_random_secret

# Email / SMTP (recommended: use a transactional email provider)
# If you use Gmail, set SMTP_HOST=smtp.gmail.com and use an App Password
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password
EMAIL_FROM=notifications@the3dindia.com
NOTIFICATION_EMAIL=admin@the3dindia.com

# OAuth / External secrets (optional)
GITHUB_CLIENT_SECRET=replace_with_github_secret

# Notes:
# - Copy this file to .env and fill in values for your environment.
# - Do NOT commit real secrets to source control.
# - On Render, set secrets in the service's Environment tab instead of using a .env file.